<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" shutdownHook="disable">
    <Appenders>

        <Console name="Info" target="SYSTEM_OUT">
            <LevelMatchFilter level="INFO" onMatch="ACCEPT" onMismatch="DENY"/>
            <PatternLayout pattern="%d{HH:mm:ss} [%-5level] %msg%n"/>
        </Console>


        <Console name="Warn" target="SYSTEM_ERR">
            <LevelMatchFilter level="WARN" onMatch="ACCEPT" onMismatch="DENY"/>
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%-4level] %msg%n"/>
        </Console>

        <Console name="Debug" target="SYSTEM_ERR">
            <LevelMatchFilter level="DEBUG" onMatch="ACCEPT" onMismatch="DENY"/>
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%-4level] %msg%n"/>
        </Console>


        <Console name="Error" target="SYSTEM_ERR">
            <LevelMatchFilter level="ERROR" onMatch="ACCEPT" onMismatch="DENY"/>
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%-5level] %msg%n"/>
        </Console>

        <File name="FileAll" fileName="logs/app.log" append="true">
            <ThresholdFilter level="DEBUG" onMatch="ACCEPT" onMismatch="DENY"/>
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%-5level] %logger{36} - %msg%n%ex"/>
        </File>

        <File name="FileErrors" fileName="logs/errors.log" append="true">
            <ThresholdFilter level="ERROR" onMatch="ACCEPT" onMismatch="DENY"/>
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%-5level] %logger{36} - %msg%n%ex"/>
        </File>
    </Appenders>

    <Loggers>
        <Root level="debug">
            <AppenderRef ref="Info"/>
            <AppenderRef ref="Warn"/>
            <AppenderRef ref="Debug"/>
            <AppenderRef ref="FileErrors"/>
            <AppenderRef ref="FileAll"/>
        </Root>
    </Loggers>
</Configuration>